# project_root/.env.example

# --- Application Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO # CRITICAL, ERROR, WARNING, INFO, DEBUG
DEV_MODE=false # true for Uvicorn reload, false for production

# --- Salesforce Configuration ---
# Choose one auth mode and fill corresponding variables
SALESFORCE_AUTH_MODE=password # "password" or "client_credentials"

# For "password" auth mode:
SALESFORCE_USERNAME=your_salesforce_username@example.com
SALESFORCE_PASSWORD=your_salesforce_password
SALESFORCE_SECURITY_TOKEN=your_salesforce_security_token
SALESFORCE_DOMAIN=test # e.g., "login" for production, "test" for sandbox. Or use INSTANCE_URL.
SALESFORCE_INSTANCE_URL= # Optional: e.g., https://your_company.my.salesforce.com

# For "client_credentials" auth mode:
SALESFORCE_CLIENT_ID=your_connected_app_client_id
SALESFORCE_CLIENT_SECRET=your_connected_app_client_secret
SALESFORCE_TOKEN_URL=https://your_domain.my.salesforce.com/services/oauth2/token # Or your sandbox equivalent

# --- Google Gemini Configuration ---
GOOGLE_API_KEY=your_google_api_key_for_gemini
GEMINI_MODEL_NAME=gemini-1.5-flash # Or other compatible model

# --- API Rate Limiting and Processing (Defaults are in app/config.py if not set here) ---
# MAX_GLOBAL_REQUESTS_PER_WINDOW=10
# GLOBAL_RATE_LIMIT_WINDOW_SECONDS=60
# MAX_CLIENT_REQUESTS_PER_WINDOW=5
# CLIENT_RATE_LIMIT_WINDOW_SECONDS=60
# MIN_SECONDS_BETWEEN_SAME_APP_REQUESTS=5
# SUSPICIOUS_THRESHOLD_REQUESTS=20
# SUSPICIOUS_WINDOW_SECONDS=60
# SUSPICIOUS_BLOCK_DURATION_SECONDS=300
# MAX_CONCURRENT_PROCESSING_SLOTS=4
# RECENTLY_PROCESSED_TTL_SECONDS=300
# ACTIVE_PROCESSING_TIMEOUT_SECONDS=900
# MAX_CONCURRENT_OCR_PAGES=3

