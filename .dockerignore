# Git specific files - crucial to reduce build context size
.git/
.gitignore
.gitattributes
.gitmodules

# Docker specific files
Dockerfile
.dockerignore

# Python virtual environments
env/
venv/
.venv/
ENV/
# Add your virtualenv DIRS here

# Python compiled files and cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.Python
pip-log.txt

# IDE / Editor specific files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
nbproject/

# macOS specific files
.DS_Store
._*

# Secrets & local configurations (secrets should be passed as environment variables at runtime)
# .env # Usually you want the .env file on the HOST, not in the image.
# If you have local config files not meant for the image:
# local_settings.py
# credentials.json

# Build artifacts / distribution
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg
*.tar.gz # If you create archives within your project that aren't needed for the image

# Test files & reports (if not needed for the production image)
# tests/
# .pytest_cache/
# .coverage
# htmlcov/
# tox.ini
# pytest.ini

# Log files
*.log
logs/

# Notebooks
*.ipynb
.ipynb_checkpoints/

# Documentation (if not served by the app)
# docs/
# site/

# Other OS specific
Thumbs.db
ehthumbs.db